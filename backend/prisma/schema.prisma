generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator prismaClassGenerator {
  provider = "prisma-class-generator"
  dryRun = "false"
  separateRelationFields = "false"
  // Prisma Client가 @prisma/client 대신 커스텀 경로로 생성되므로 enum import 경로를 맞춰줘야 한다
  clientImportPath = "generated/prisma"
}

// ──────────────────────────────────────────
// 인증 관련 모델 (NextAuth)
// ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?
  hashedPassword String?   @map("hashed_password") // Credentials 로그인용 (OAuth 유저는 null)
  description    String?
  role           String    @default("USER")

  accounts     Account[]
  sessions     Session[]
  roomMembers  RoomMember[]
  messages     Message[]
  messageReads MessageRead[]
  roomLikes    RoomLike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────
// 채팅방 / 모임
// ──────────────────────────────────────────

model Room {
  id   String   @id @default(cuid())
  type RoomType @default(DIRECT)

  // ── 채팅방 기본 정보 ──────────────────────
  name         String? // 단체 채팅방 이름 (1대1은 null)
  slug         String? @unique // URL용 식별자 (DIRECT 채팅은 null)
  coverImage   String? @map("cover_image") // 채팅방 커버 이미지
  profileImage String? @map("profile_image") // 채팅방 프로필 이미지

  // ── 모임 전용 필드 (GROUP 타입에서만 사용) ──
  description      String?       @db.Text // 모임 상세 설명 (마크다운)
  shortDescription String?       @map("short_description") // 목록용 한 줄 소개
  memberLimit      Int?          @map("member_limit") // 최대 인원 (null이면 무제한)
  category         RoomCategory? // 모임 카테고리
  address          String? // 모임 장소 주소
  date             DateTime? // 모임 일정 (DIRECT 채팅은 null)

  members  RoomMember[]
  messages Message[]
  likes    RoomLike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rooms")
}

enum RoomType {
  DIRECT // 1대1 채팅
  GROUP // 단체 채팅 / 모임
}

enum RoomCategory {
  STUDY // 스터디
  SPORTS // 스포츠
  FOOD // 맛집
  TRAVEL // 여행
  HOBBY // 취미
  CULTURE // 문화/예술
  TECH // IT/기술
  ETC // 기타
}

// ──────────────────────────────────────────
// 모임 좋아요
// ──────────────────────────────────────────

model RoomLike {
  id     String @id @default(cuid())
  roomId String @map("room_id")
  userId String @map("user_id")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  // 한 유저가 같은 모임에 중복 좋아요 불가
  @@unique([roomId, userId])
  @@map("room_likes")
}

// ──────────────────────────────────────────
// 채팅방 참여자
// ──────────────────────────────────────────

model RoomMember {
  id        String         @id @default(cuid())
  roomId    String         @map("room_id")
  userId    String         @map("user_id")
  role      RoomMemberRole @default(MEMBER)
  invitedBy String?        @map("invited_by") // 초대한 사람의 userId

  // null이면 현재 참여 중, 값이 있으면 나간 상태
  leftAt     DateTime? @map("left_at")
  // 마지막으로 읽은 시각 (안 읽은 메시지 수 계산용)
  lastReadAt DateTime? @map("last_read_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  // 같은 방에 같은 유저 중복 참여 불가
  @@unique([roomId, userId])
  @@map("room_members")
}

enum RoomMemberRole {
  OWNER // 방장
  MEMBER // 일반 참여자
}

// ──────────────────────────────────────────
// 메시지
// ──────────────────────────────────────────

model Message {
  id       String @id @default(cuid())
  roomId   String @map("room_id")
  senderId String @map("sender_id")

  // 파일만 전송하는 경우 텍스트 없을 수 있으므로 nullable
  content String? @db.Text

  isEdited  Boolean   @default(false) @map("is_edited")
  // soft delete — null이면 정상, 값이 있으면 삭제된 메시지
  deletedAt DateTime? @map("deleted_at")

  room        Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User                @relation(fields: [senderId], references: [id])
  attachments MessageAttachment[]
  reads       MessageRead[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("messages")
}

// ──────────────────────────────────────────
// 첨부파일
// ──────────────────────────────────────────

model MessageAttachment {
  id        String         @id @default(cuid())
  messageId String         @map("message_id")
  type      AttachmentType
  url       String // S3 등 스토리지 URL
  name      String // 원본 파일명
  size      Int // 파일 크기 (bytes)
  mimeType  String         @map("mime_type")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("message_attachments")
}

enum AttachmentType {
  IMAGE
  FILE
}

// ──────────────────────────────────────────
// 배너
// ──────────────────────────────────────────

model Banner {
  id       String @id @default(cuid())
  imageUrl String @map("image_url")
  linkUrl  String @map("link_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

// ──────────────────────────────────────────
// 읽음 여부
// ──────────────────────────────────────────

model MessageRead {
  id        String @id @default(cuid())
  messageId String @map("message_id")
  userId    String @map("user_id")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now()) @map("read_at")

  // 한 유저가 같은 메시지를 중복 읽음 처리 불가
  @@unique([messageId, userId])
  @@map("message_reads")
}
